# CommonSource Oracle Cloud Free Tier environment template.
# Copy to commonsource.env on the VM and fill real values there.

COMMONSOURCE_PUBLIC_URL=https://commonsource.example.com
COMMONSOURCE_CORS_ORIGINS=https://commonsource.example.com

# Authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
COMMONSOURCE_JWT_SECRET=replace-with-a-64-character-random-secret
COMMONSOURCE_REQUIRE_JWT_SECRET=1
COMMONSOURCE_ACCESS_TOKEN_SECONDS=900
COMMONSOURCE_REFRESH_TOKEN_SECONDS=1209600

# Gemini Flash primary provider
COMMONSOURCE_LLM_PROVIDER=gemini
COMMONSOURCE_LLM_MODEL=gemini-2.5-flash
COMMONSOURCE_GEMINI_MODEL=gemini-2.5-flash
COMMONSOURCE_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
COMMONSOURCE_GEMINI_THINKING_BUDGET=0
GEMINI_API_KEY=

# Optional local fallback. Leave Ollama disabled on the free VM unless you add swap/disk.
COMMONSOURCE_LLM_FALLBACK_PROVIDERS=
OLLAMA_BASE_URL=http://localhost:11434
COMMONSOURCE_QWEN_MODEL=qwen2.5:1.5b

# Qdrant runs locally through Docker.
COMMONSOURCE_USE_QDRANT=1
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=commonsource_chunks
QDRANT_RETRY_SECONDS=15

# Email OTP delivery. Gmail requires a Google App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-character-gmail-app-password
SMTP_FROM=CommonSource <your-gmail-address@gmail.com>

# Runtime
COMMONSOURCE_PORT=5050
PYTHONIOENCODING=utf-8
COMMONSOURCE_TRANSLATION_WORKERS=2
COMMONSOURCE_TRANSLATION_MAX_DOCUMENT_CHARS=250000
