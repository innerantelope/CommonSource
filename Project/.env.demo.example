# CommonSource zero-cost demo deployment template.
# Copy to Project/app/.env or load these variables in your shell/service manager.

COMMONSOURCE_PUBLIC_URL=https://YOUR_PUBLIC_HOSTNAME
COMMONSOURCE_CORS_ORIGINS=https://YOUR_PUBLIC_HOSTNAME,http://127.0.0.1:5050,http://localhost:5050

# Authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
COMMONSOURCE_JWT_SECRET=replace-with-a-64-character-random-secret
COMMONSOURCE_REQUIRE_JWT_SECRET=1
COMMONSOURCE_ACCESS_TOKEN_SECONDS=900
COMMONSOURCE_REFRESH_TOKEN_SECONDS=1209600

# Email OTP delivery
# Gmail requires a Google App Password, not your normal Gmail password.
# The app also accepts SMTP_HOST/SMTP_PORT/SMTP_USERNAME/SMTP_PASSWORD/SMTP_FROM.
COMMONSOURCE_SMTP_HOST=smtp.gmail.com
COMMONSOURCE_SMTP_PORT=587
COMMONSOURCE_SMTP_USER=your-gmail-address@gmail.com
COMMONSOURCE_SMTP_PASSWORD=your-16-character-gmail-app-password
COMMONSOURCE_SMTP_FROM=CommonSource <your-gmail-address@gmail.com>
COMMONSOURCE_EMAIL_FROM=CommonSource <your-gmail-address@gmail.com>
COMMONSOURCE_RESEND_API_KEY=

# Gemini Flash is primary; local Qwen remains the no-cost fallback.
COMMONSOURCE_LLM_PROVIDER=gemini
COMMONSOURCE_LLM_FALLBACK_PROVIDERS=ollama
COMMONSOURCE_LLM_MODEL=gemini-2.5-flash
COMMONSOURCE_GEMINI_MODEL=gemini-2.5-flash
COMMONSOURCE_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
COMMONSOURCE_GEMINI_THINKING_BUDGET=0
COMMONSOURCE_QWEN_MODEL=qwen2.5:1.5b
COMMONSOURCE_METADATA_AI=1
COMMONSOURCE_METADATA_LLM_TIMEOUT=45
COMMONSOURCE_TOPIC_SUMMARY_TIMEOUT=60
COMMONSOURCE_SCRIPT_MAX_TOKENS=500
COMMONSOURCE_TRANSLATION_WORKERS=4
COMMONSOURCE_TRANSLATION_MAX_DOCUMENT_CHARS=250000

# Optional free API providers. Leave blank when using local Ollama.
OPENROUTER_API_KEY=
COMMONSOURCE_OPENROUTER_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
COMMONSOURCE_GROQ_MODEL=llama-3.1-8b-instant

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant local or cloud
COMMONSOURCE_USE_QDRANT=1
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=commonsource_chunks
QDRANT_RETRY_SECONDS=15

# Flask
COMMONSOURCE_PORT=5050
PYTHONIOENCODING=utf-8
